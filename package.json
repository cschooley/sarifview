{
  "name": "sarifview",
  "displayName": "SARIF View",
  "description": "Auto-populate the VS Code Problems panel from .sarif files in your workspace — no clicks required.",
  "version": "0.1.0",
  "publisher": "cschooley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cschooley/sarifview"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "sarif",
    "security",
    "sast",
    "semgrep",
    "gitleaks",
    "grype"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "SARIF View",
      "properties": {
        "sarifview.directory": {
          "type": "string",
          "default": ".sarif",
          "description": "Directory to scan for .sarif files, relative to the workspace root."
        }
      }
    },
    "commands": [
      {
        "command": "sarifview.refresh",
        "title": "SARIF View: Refresh"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "test": "mocha --require ts-node/register src/test/**/*.test.ts",
    "package": "node --require ./scripts/file-polyfill.js ./node_modules/.bin/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.7",
    "markdown-it": "^14.1.1",
    "linkify-it": "^5.0.2"
  }
}
